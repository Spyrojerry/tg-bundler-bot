# ── Optional seed wallet ──────────────────────────────────────────────────────
# You can leave this empty and add wallets from Telegram with:
# /addwallet <address>
WALLET_ADDRESS=

# Your own trading wallet to monitor for first buys and use for confirmed sells.
# This is required for trading-wallet detection; WALLET_ADDRESS is not used as a fallback.
TRADING_WALLET_ADDRESS=

# ── Solana RPC ─────────────────────────────────────────────────────────────────
# Free public endpoint — replace with Helius/QuickNode/Triton for production
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional websocket endpoint. If omitted, it is derived from SOLANA_RPC_URL.
# For Helius this is usually:
# SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# How often to poll the wallet for new tokens (ms). Default: 5000
WALLET_POLL_INTERVAL=5000

# Minimum first-buy size in SOL before monitoring a new token.
# Set 0 to disable. Poll-only detections are skipped when this is enabled
# because the original buy size is unknown.
MIN_BUY_SOL=8

# ── GMGN API ───────────────────────────────────────────────────────────────────
# Get your key at https://gmgn.ai/ai  (apply for API access)
GMGN_API_KEY=YOUR_GMGN_API_KEY_HERE

# GMGN signing key. Not used by the Jupiter Swap V2 sell flow.
GMGN_PRIVATE_KEY=

# GMGN API host. Routes are built as /v1/token/security and /v1/token/info.
# If GMGN gives you a dedicated host, set it here.
GMGN_API_BASE_URL=https://gmgn.ai

# direct = fetch GMGN HTTP routes directly
# cli    = use npx gmgn-cli token ... --raw
# auto   = try direct first, then fall back to CLI if blocked
GMGN_FETCH_MODE=cli

# ── Confirmed sell execution ──────────────────────────────────────────────────
# Jupiter Swap V2 signs the sell transaction with this Solana wallet key.
# It must belong to TRADING_WALLET_ADDRESS. Supports base58 or JSON byte array.
JUPITER_PRIVATE_KEY=

# Jupiter Swap V2 requires x-api-key.
JUPITER_API_KEY=
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2

# Helius API key for early bundler detection and monitoring.
HELIUS_API_KEY=

# When filters fail, the bot sells using Jupiter Swap V2.
SELL_PERCENT=100

# Kept for compatibility. Jupiter Swap V2 uses its own slippage estimation.
SELL_AUTO_SLIPPAGE=false

# Kept for compatibility with older sell flows.
SELL_SLIPPAGE=1

# Priority fee for Jupiter Swap V2. 0.000012 SOL is about $0.001 at ~$83/SOL.
SELL_PRIORITY_FEE_SOL=0.000012

# Kept for compatibility with older sell flows.
SELL_ANTI_MEV=false

# After a filter fail, wait until the estimated sell is at least this profitable.
SELL_MIN_PROFIT_PCT=0.1
SELL_PROFIT_CHECK_INTERVAL_MS=2000

# ── Scheduler / Rate-limiter ───────────────────────────────────────────────────
# Target interval between consecutive GMGN polls for each token (ms)
MONITOR_INTERVAL=2000

# Legacy fallback setting. Linked trading-wallet tokens now stop at the
# active Apply filters at sample # decision instead of this time window.
MONITOR_WINDOW_MS=60000

# Minimum gap between any two GMGN HTTP requests (ms). Increase if you hit 429s.
RATE_LIMIT_MIN_TIME=500

# Max concurrent GMGN requests in flight at once
RATE_LIMIT_MAX_CONCURRENT=1

# ── Persistence ────────────────────────────────────────────────────────────────
DB_PATH=./data/monitor.db

# ── Logging ────────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create with @BotFather, then add it here.
TELEGRAM_BOT_TOKEN=

# Optional: chat id that receives automatic sample/summary cards.
# Commands work from any chat that messages the bot.
TELEGRAM_CHAT_ID=

# Fly.io / health check port
PORT=8080
