# ── Trading wallet (PumpPortal Lightning) ─────────────────────────────────────
# Required for insider buys/sells. Must match PUMPPORTAL_WALLET_ADDRESS.
TRADING_WALLET_ADDRESS=

# ── Solana RPC ─────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

HELIUS_API_KEY=

# ── GMGN API ───────────────────────────────────────────────────────────────────
GMGN_API_KEY=YOUR_GMGN_API_KEY_HERE
GMGN_API_KEY_2=
GMGN_API_KEY_3=
GMGN_API_KEY_4=
GMGN_API_BASE_URL=https://gmgn.ai
GMGN_FETCH_MODE=cli

# ── PumpPortal Lightning trade execution ──────────────────────────────────────
PUMPPORTAL_API_KEY=
PUMPPORTAL_WALLET_ADDRESS=

# Jupiter API (price + metadata; buys/sells use PumpPortal Lightning)
JUPITER_API_KEY=
JUPITER_PRICE_API_KEY=
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2

# ── Insider Helius pool (bot 1–4) ───────────────────────────────────────────
# INSIDER_HELIUS_API_KEY must be on a Helius Developer+ plan for Enhanced WSS.
INSIDER_HELIUS_API_KEY=
INSIDER_HELIUS_PROJECT_ID=
INSIDER_SOLANA_RPC_URL=
INSIDER_SOLANA_WS_URL=

INSIDER_HELIUS_API_KEY_2=
INSIDER_HELIUS_PROJECT_ID_2=
INSIDER_SOLANA_RPC_URL_2=
INSIDER_SOLANA_WS_URL_2=

INSIDER_HELIUS_API_KEY_3=
INSIDER_HELIUS_PROJECT_ID_3=
INSIDER_SOLANA_RPC_URL_3=
INSIDER_SOLANA_WS_URL_3=

INSIDER_HELIUS_API_KEY_4=
INSIDER_HELIUS_PROJECT_ID_4=
INSIDER_SOLANA_RPC_URL_4=
INSIDER_SOLANA_WS_URL_4=

# Top-level feePayer funder for funder-first discovery
INSIDER_FEEPAYER_FUNDER_ADDRESS=

# Auto-start discovery flows on boot (Telegram Start/Stop still works)
INSIDER_FOLLOW_WALLET_ENABLED=false
INSIDER_FOLLOW_WALLET_VERBOSE_LOGS=true
INSIDER_FUNDER_FIRST_ENABLED=false
INSIDER_FOLLOW_TOKEN_ENABLED=false
INSIDER_FOLLOW_TOKEN_MAX_MIGRATION_AGE_SEC=5

# Default follow wallets (Bot 1; loaded paused until resumed)
INSIDER_FOLLOW_WALLET=
INSIDER_FOLLOW_WALLET_2=
INSIDER_FOLLOW_WALLET_3=
INSIDER_FOLLOW_WALLET_4=

INSIDER_BUNDLER_BUY_MIN_USD=100
INSIDER_BUNDLER_BUY_MAX_USD=200
INSIDER_REQUIRED_SELLS=5

MIN_BUY_SOL=6

INSIDER_BUY_SOL=0.025
INSIDER_NORMAL_BUY_SOL=0.18
INSIDER_LOW_FUNDING_BUY_SOL=0.025
INSIDER_ENTRY_MC=50000
INSIDER_EXIT_MC=75000
INSIDER_EXIT_PERCENT=40

SELL_PERCENT=100
SELL_AUTO_SLIPPAGE=false
SELL_SLIPPAGE=50
SELL_PRIORITY_FEE_SOL=0.000012

RATE_LIMIT_MIN_TIME=500
RATE_LIMIT_MAX_CONCURRENT=1

DB_PATH=./data/monitor.db
LOG_LEVEL=info

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PORT=8080
